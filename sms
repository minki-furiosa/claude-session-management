# -------------------------- Tree class and locking ---------------------------


def _iso_now() -> str:
    return _dt.datetime.now(_dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def _file_timestamp() -> str:
    """Filesystem-safe UTC timestamp for backup filenames (no colons)."""
    return _dt.datetime.now(_dt.timezone.utc).strftime("%Y%m%d-%H%M%S-%f")


def _jsonl_has_real_conversation(path: Path) -> bool:
    """True if the jsonl has at least one user message — i.e. real work, not
    just metadata stubs (last-prompt / custom-title / agent-name / mode) that
    Claude writes when a session UUID is opened without its content present."""
    try:
        for line in path.read_text().splitlines():
            try:
                if json.loads(line).get("type") == "user":
                    return True
            except json.JSONDecodeError:
                continue
    except OSError:
        pass
    return False


@contextmanager
def _tree_lock(sms_dir: Path) -> Iterator[None]:
    """Hold a file lock for the duration of a tree mutation."""
    sms_dir.mkdir(parents=True, exist_ok=True)
    lock_path = sms_dir / ".lock"
    with open(lock_path, "w") as f:
        fcntl.flock(f.fileno(), fcntl.LOCK_EX)
        try:
            yield
        finally:
            fcntl.flock(f.fileno(), fcntl.LOCK_UN)


class Tree:
    def __init__(self, path: Path, data: dict) -> None:
        self.path = path
        self.data = data

    @classmethod
    def load(cls, cwd: Path) -> "Tree":
        path = sms_root(cwd) / "tree.json"
        if not path.exists():
            return cls(path, {"branches": {}})
        try:
            data = json.loads(path.read_text())
        except json.JSONDecodeError as e:
            sys.stderr.write(
                f"error: tree.json at {path} is not valid JSON ({e}). "
                "Refusing to overwrite. Inspect manually.\n"
            )
            raise SystemExit(2)
        if not isinstance(data, dict) or "branches" not in data:
            sys.stderr.write(f"error: tree.json at {path} has unexpected shape\n")
            raise SystemExit(2)
        return cls(path, data)

    def save(self) -> None:
        self.path.parent.mkdir(parents=True, exist_ok=True)
        tmp = self.path.with_suffix(".json.tmp")
        tmp.write_text(json.dumps(self.data, indent=2, sort_keys=True) + "\n")
        os.replace(tmp, self.path)

    # --- mutators ---

    def add_branch(self, name: str, parent: str | None) -> None:
        if name in self.data["branches"]:
            sys.stderr.write(f"error: branch '{name}' already in tree.json\n")
            raise SystemExit(1)
        self.data["branches"][name] = {
            "parent": parent,
            "state": "active",
            "created_at": _iso_now(),
            "sessions": {},
        }

    def add_session(
        self, branch: str, uuid: str, name: str,
        parent_uuid: str | None, is_main: bool,
    ) -> None:
        b = self.data["branches"].get(branch)
        if b is None:
            sys.stderr.write(f"error: branch '{branch}' not in tree.json\n")
            raise SystemExit(1)
        if is_main:
            for u, s in b["sessions"].items():
                s["is_main"] = False
        b["sessions"][uuid] = {
            "name": name,
            "parent_uuid": parent_uuid,
            "is_main": is_main,
            "created_at": _iso_now(),
        }

    def set_main(self, branch: str, uuid: str) -> None:
        b = self.data["branches"].get(branch)
        if b is None or uuid not in b["sessions"]:
            sys.stderr.write(f"error: session {uuid} not on branch '{branch}'\n")
            raise SystemExit(1)
        for u, s in b["sessions"].items():
            s["is_main"] = (u == uuid)

    def set_state(self, branch: str, state: Literal["active", "merged", "backlog"]) -> None:
        if branch not in self.data["branches"]:
            sys.stderr.write(f"error: branch '{branch}' not in tree.json\n")
            raise SystemExit(1)
        self.data["branches"][branch]["state"] = state

    def find_session(self, uuid: str) -> tuple[str, dict] | None:
        for name, b in self.data["branches"].items():
            if uuid in b["sessions"]:
                return name, b["sessions"][uuid]
        return None

    def branch(self, name: str) -> dict | None:
        return self.data["branches"].get(name)


# -------------------------- Symlink helpers ----------------------------------


def canonical_session_path(cwd: Path, branch: str, uuid: str) -> Path:
    return sms_root(cwd) / "sessions" / branch / f"{uuid}.jsonl"


def canonical_session_subdir(cwd: Path, branch: str, uuid: str) -> Path:
    return sms_root(cwd) / "sessions" / branch / uuid


def make_session_symlink(cwd: Path, branch: str, uuid: str) -> None:
    canonical = canonical_session_path(cwd, branch, uuid)
    canonical.parent.mkdir(parents=True, exist_ok=True)
    link = claude_projects_dir(cwd) / f"{uuid}.jsonl"
    link.parent.mkdir(parents=True, exist_ok=True)
    if link.is_symlink():
        existing_target = Path(os.readlink(link))
        if existing_target == canonical:
            pass  # already correct
        else:
            link.unlink()
            link.symlink_to(canonical)
    elif link.exists():
        # A regular file sits where our symlink should go. This happens when a
        # session UUID is opened in the picker while no symlink exists yet —
        # Claude then writes a fresh jsonl in place, splitting it from the
        # canonical copy. Recover automatically instead of refusing:
        #   - identical to canonical  -> just replace with the symlink
        #   - differs                 -> back it up first, then link
        # so no data is ever silently lost.
        if canonical.exists() and filecmp.cmp(link, canonical, shallow=False):
            link.unlink()
            link.symlink_to(canonical)
        elif _jsonl_has_real_conversation(link):
            # The stray file holds an actual conversation — never discard it.
            backup = link.with_name(f"{uuid}.jsonl.conflict-{_file_timestamp()}")
            link.rename(backup)
            link.symlink_to(canonical)
            sys.stderr.write(
                f"warning: {link} existed as a regular file with its own "
                f"conversation, differing from the canonical session. Backed it "
                f"up to {backup} and linked to canonical. Inspect the backup.\n"
            )
        else:
            # Just a metadata stub (no user messages) that Claude wrote when the
            # UUID was opened without a symlink. Harmless — replace silently.
            link.unlink()
            link.symlink_to(canonical)
    else:
        link.symlink_to(canonical)

    # Subdir, if canonical has one
    canonical_sub = canonical_session_subdir(cwd, branch, uuid)
    if canonical_sub.is_dir():
        sub_link = claude_projects_dir(cwd) / uuid
        if sub_link.is_symlink():
            if Path(os.readlink(sub_link)) != canonical_sub:
                sub_link.unlink()
                sub_link.symlink_to(canonical_sub, target_is_directory=True)
        elif sub_link.exists():
            sys.stderr.write(
                f"warning: {sub_link} exists as a regular directory; "
                "leaving alone\n"
            )
        else:
            sub_link.symlink_to(canonical_sub, target_is_directory=True)


def remove_session_symlink(cwd: Path, uuid: str) -> None:
    link = claude_projects_dir(cwd) / f"{uuid}.jsonl"
    if link.is_symlink():
        link.unlink()
    sub_link = claude_projects_dir(cwd) / uuid
    if sub_link.is_symlink():
        sub_link.unlink()


def scan_projects_dir_for_sms_symlinks(cwd: Path) -> dict[str, Path]:
    """Return {uuid: canonical_target} for entries that are symlinks into .git/sms/sessions/."""
    out: dict[str, Path] = {}
    projects = claude_projects_dir(cwd)
    if not projects.exists():
        return out
    sms_sessions_prefix = str(sms_root(cwd) / "sessions") + os.sep
    for entry in projects.iterdir():
        if not entry.is_symlink():
            continue
        if not entry.name.endswith(".jsonl"):
            continue
        raw_target = os.readlink(entry)
        target_path = Path(raw_target)
        if not target_path.is_absolute():
            target_path = (entry.parent / target_path).resolve()
        target = str(target_path)
        if not target.startswith(sms_sessions_prefix):
            continue
        uuid = entry.name[:-len(".jsonl")]
        out[uuid] = target_path
    return out


# -------------------------- Subcommands ------------------------------------


def cmd_debug_paths(args: argparse.Namespace) -> int:
    """Dump resolved paths for the current cwd. Used by tests."""
    cwd = Path.cwd()
    print(f"main_git_dir={find_main_git_dir(cwd)}")
    print(f"branch={current_branch(cwd)}")
    print(f"cwd_hash={cwd_hash(cwd)}")
    print(f"projects_dir={claude_projects_dir(cwd)}")
    print(f"sms_root={sms_root(cwd)}")
    return 0


def cmd_debug_tree(args: argparse.Namespace) -> int:
    """(internal) tree.json mutations used by tests."""
    cwd = Path.cwd()
    with _tree_lock(sms_root(cwd)):
        t = Tree.load(cwd)
        sub = args.tree_sub
        if sub == "init":
            pass  # load was enough
        elif sub == "add-branch":
            t.add_branch(args.name, args.parent)
        elif sub == "add-session":
            is_main = args.is_main.lower() == "true"
            t.add_session(args.branch, args.uuid, args.name, None, is_main)
        elif sub == "set-main":
            t.set_main(args.branch, args.uuid)
        elif sub == "set-state":
            t.set_state(args.branch, args.state)
        else:
            sys.stderr.write(f"error: unknown debug-tree sub {sub}\n")
            return 2
        t.save()
    return 0


def cmd_debug_symlink(args: argparse.Namespace) -> int:
    cwd = Path.cwd()
    if args.sym_sub == "make":
        make_session_symlink(cwd, args.branch, args.uuid)
    elif args.sym_sub == "remove":
        remove_session_symlink(cwd, args.uuid)
    elif args.sym_sub == "scan":
        for uuid, target in scan_projects_dir_for_sms_symlinks(cwd).items():
            print(f"{uuid}={target}")
    elif args.sym_sub == "fix-visibility":
        _make_session_picker_visible(cwd, args.uuid)
    else:
        return 2
    return 0


def cmd_sync(args: argparse.Namespace) -> int:
    cwd = Path.cwd()
    branch = current_branch(cwd)
    t = Tree.load(cwd)

    desired_uuids: set[str] = set()
    b = t.branch(branch)
    if b is not None:
        desired_uuids = set(b["sessions"].keys())

    existing = scan_projects_dir_for_sms_symlinks(cwd)
    existing_uuids = set(existing.keys())

    sessions_root = str(sms_root(cwd) / "sessions") + os.sep
    branch_prefix = str(sms_root(cwd) / "sessions" / branch) + os.sep
    to_remove = {
        u for u in existing_uuids
        if not str(existing[u]).startswith(branch_prefix)
    }
    to_create = desired_uuids - existing_uuids

    for u in sorted(to_remove):
        remove_session_symlink(cwd, u)
    for u in sorted(to_create):
        make_session_symlink(cwd, branch, u)
    return 0


def _default_session_name(branch: str, existing_count: int) -> str:
    """Generate a useful default session name when --name is not given.

    First session on a branch gets the branch name verbatim. Subsequent
    sessions are numbered: 'branch (2)', 'branch (3)', ... so they stay
    distinguishable in the /resume picker.
    """
    if existing_count == 0:
        return branch
    return f"{branch} ({existing_count + 1})"


def report_created_session(uuid: str, name: str) -> None:
    """Print a session-created summary. The picker title is shown prominently
    (the user finds sessions by title in the /resume picker), and the UUID is
    always the LAST line so scripts/tests can parse it with `splitlines()[-1]`.
    """
    if name:
        print(f'Created session — picker title: "{name}"')
    print(uuid)


def cmd_new(args: argparse.Namespace) -> int:
    cwd = Path.cwd()

    # Pre-check: refuse if branch already in tree.json (before touching git)
    t = Tree.load(cwd)
    if t.branch(args.branch) is not None:
        sys.stderr.write(
            f"error: branch '{args.branch}' already in tree.json. "
            f"To re-attach, manually edit tree.json or implement `sms adopt` (future).\n"
        )
        return 1

    # Parent encodes sms-tree lineage, not arbitrary git branch position.
    # Capture parent only if the current branch is itself sms-tracked;
    # otherwise this new branch is a root (parent=None). Also None on detached HEAD.
    candidate = current_branch_or_none(cwd)
    parent = candidate if candidate is not None and t.branch(candidate) is not None else None

    # Create branch
    subprocess.run(
        ["git", "checkout", "-b", args.branch],
        cwd=cwd, check=True,
    )

    new_uuid = str(_uuid.uuid4())
    with _tree_lock(sms_root(cwd)):
        t = Tree.load(cwd)
        t.add_branch(args.branch, parent)
        # First session on the branch — default name is just the branch.
        name = args.name or _default_session_name(args.branch, 0)
        t.add_session(args.branch, new_uuid, name, None, True)
        t.save()

    (sms_root(cwd) / "sessions" / args.branch).mkdir(parents=True, exist_ok=True)
    make_session_symlink(cwd, args.branch, new_uuid)

    if args.launch:
        print(new_uuid)
        os.execvp("claude", ["claude", "--session-id", new_uuid])

    if not args.no_materialize:
        materialize_session(cwd, new_uuid, name=name)

    report_created_session(new_uuid, name)
    return 0


INTERACTIVE_ENTRYPOINT = "claude-vscode"


def materialize_session(cwd: Path, uuid: str, name: str = "") -> None:
    """Give a freshly-created session enough on-disk content that Claude Code's
    `/resume` picker will show it, with the chosen display name.

    Runs a brief non-interactive `claude --print`. Passes `--name` so the
    picker shows the label (stored as a `custom-title` jsonl entry).

    IMPORTANT: `claude --print` marks the session with `entrypoint:sdk-cli`,
    and the picker HIDES sdk-cli (non-interactive) sessions — even after later
    interactive use. So immediately after the print run we rewrite those
    markers to the interactive entrypoint via _make_session_picker_visible().

    This runs synchronously (not backgrounded): the picker can't show the
    session until both the print run and the entrypoint rewrite finish, so
    there's nothing to gain by returning early.
    """
    cmd = ["claude", "--session-id", uuid]
    if name:
        cmd += ["--name", name]
    cmd += [
        "--print",
        "This session was just initialized by `sms new`/`sms session-new`. "
        "Reply with only the word 'ok' and nothing else.",
    ]
    try:
        subprocess.run(
            cmd,
            cwd=cwd,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=120,
        )
    except (OSError, subprocess.TimeoutExpired) as e:
        sys.stderr.write(
            f"warning: `claude --print` for materialization failed: {e}\n"
            f"Session {uuid} may not appear in the picker until you open it "
            f"once via terminal.\n"
        )
        return
    _make_session_picker_visible(cwd, uuid)


def _make_session_picker_visible(cwd: Path, uuid: str) -> None:
    """Rewrite `entrypoint:sdk-cli` markers (left by `claude --print`) to the
    interactive entrypoint, so the /resume picker stops hiding the session.

    Edits through the projects-dir path, which is normally a symlink to the
    canonical jsonl; writing follows the link and preserves the canonical
    file's inode.
    """
    path = claude_projects_dir(cwd) / f"{uuid}.jsonl"
    if not path.exists():
        return
    content = path.read_text()
    needle = '"entrypoint":"sdk-cli"'
    if needle not in content:
        return
    path.write_text(content.replace(needle, f'"entrypoint":"{INTERACTIVE_ENTRYPOINT}"'))


def stamp_session_title(canonical: Path, uuid: str, title: str) -> None:
    """Strip any existing `custom-title`/`agent-name` lines from the jsonl
    and write fresh ones matching this session's UUID and the chosen title.

    Used by `sms fork`: a copied parent jsonl carries the parent's title
    metadata. If we only APPEND a new title line, Claude re-reads the
    inherited entries on resume and overrides with the parent's name.
    Stripping and rewriting puts our title where Claude actually finds it.
    """
    if not title:
        return
    new_lines = [
        json.dumps({"type": "custom-title", "customTitle": title, "sessionId": uuid}),
        json.dumps({"type": "agent-name",   "agentName":   title, "sessionId": uuid}),
    ]
    canonical.parent.mkdir(parents=True, exist_ok=True)
    if canonical.exists():
        kept = [
            line for line in canonical.read_text().splitlines()
            if '"type":"custom-title"' not in line
            and '"type": "custom-title"' not in line
            and '"type":"agent-name"' not in line
            and '"type": "agent-name"' not in line
        ]
        canonical.write_text("\n".join(new_lines + kept) + "\n")
    else:
        canonical.write_text("\n".join(new_lines) + "\n")


# Markers that uniquely identify sms's own SessionStart hook output.
_SMS_HOOK_MARKERS = (
    "=== sms session role ===",
    "=== sms context ===",
    "=== sms rules ===",
)


def _attachment_texts(attachment: dict) -> list[str]:
    """Collect the text payloads of a hook attachment, across the shapes Claude
    Code uses: `hook_success` stores it in `stdout` (str); the
    `hook_additional_context` attachment stores it in `content` (a list of
    strings, or a str). We check all of them for sms markers."""
    texts: list[str] = []
    stdout = attachment.get("stdout")
    if isinstance(stdout, str):
        texts.append(stdout)
    content = attachment.get("content")
    if isinstance(content, str):
        texts.append(content)
    elif isinstance(content, list):
        texts.extend(x for x in content if isinstance(x, str))
    return texts


def strip_inherited_sms_hook_context(canonical: Path) -> None:
    """Drop sms SessionStart-hook attachments copied from a parent transcript.

    A fork is a byte copy of its parent's jsonl, so it inherits every hook
    attachment the hook left in the parent — including 'You are the MAIN
    session' and 'forked from <grandparent>'. Left in place, the fork reads
    those as facts about itself and may believe it is the original (and repeat
    the parent's actions, e.g. forking again). We remove them here; the fork's
    OWN next session start re-injects correct, current context from the hook.

    Claude records the hook's output in TWO attachment shapes — `hook_success`
    (text in `stdout`) and `hook_additional_context` (text in `content`) — so
    we check both. Only sms's own hook attachments (identified by the markers)
    are removed; other hooks' attachments and all real messages are preserved.
    """
    if not canonical.exists():
        return
    out: list[str] = []
    for line in canonical.read_text().splitlines():
        try:
            d = json.loads(line)
            if d.get("type") == "attachment":
                texts = _attachment_texts(d.get("attachment", {}))
                if any(m in t for t in texts for m in _SMS_HOOK_MARKERS):
                    continue  # drop this inherited sms-hook attachment
        except (json.JSONDecodeError, AttributeError):
            pass
        out.append(line)
    canonical.write_text("\n".join(out) + "\n")


def cmd_session_delete(args: argparse.Namespace) -> int:
    """Delete a session entirely: canonical files, symlinks in all worktrees,
    file-history/session-env caches, and the tree.json entry.

    Refuses to delete the currently-running Claude session (the one this
    process was invoked from) — start another session first.
    """
    cwd = Path.cwd()
    t = Tree.load(cwd)
    resolved = _resolve_uuid_prefix(t, args.target)
    if resolved is None:
        sys.stderr.write(f"error: no session matches '{args.target}'\n")
        return 1
    if resolved[0] == "__ambiguous__":
        sys.stderr.write(f"error: ambiguous prefix '{args.target}'\n")
        return 1
    branch, uuid = resolved

    current = os.environ.get("CLAUDE_CODE_SESSION_ID") or os.environ.get("CLAUDE_SESSION_ID")
    if current == uuid:
        sys.stderr.write(
            f"error: refusing to delete the currently-running session ({uuid}). "
            f"Start another session first, then delete this one from there.\n"
        )
        return 1

    # 1. Canonical jsonl + subdir
    canonical = canonical_session_path(cwd, branch, uuid)
    if canonical.is_symlink() or canonical.exists():
        canonical.unlink()
    canonical_sub = canonical_session_subdir(cwd, branch, uuid)
    if canonical_sub.is_dir() and not canonical_sub.is_symlink():
        shutil.rmtree(canonical_sub)
    elif canonical_sub.is_symlink():
        canonical_sub.unlink()

    # 2. Symlinks in any worktree's projects dir
    projects_root = home_dir() / ".claude" / "projects"
    if projects_root.is_dir():
        for pd in projects_root.iterdir():
            if not pd.is_dir():
                continue
            for name in (f"{uuid}.jsonl", uuid):
                p = pd / name
                if p.is_symlink():
                    p.unlink()

    # 3. UUID-keyed caches outside projects/
    for path in (
        home_dir() / ".claude" / "file-history" / uuid,
        home_dir() / ".claude" / "session-env" / uuid,
    ):
        if path.is_dir():
            shutil.rmtree(path)
        elif path.exists() or path.is_symlink():
            path.unlink()

    # 4. tree.json entry
    with _tree_lock(sms_root(cwd)):
        t = Tree.load(cwd)
        b = t.branch(branch)
        if b is not None and uuid in b["sessions"]:
            del b["sessions"][uuid]
            t.save()

    print(f"deleted session {uuid} (was on branch {branch})")
    return 0


def cmd_session_new(args: argparse.Namespace) -> int:
    """Add a new blank session to the current sms-tracked branch."""
    cwd = Path.cwd()
    branch = current_branch_or_none(cwd)
    if branch is None:
        sys.stderr.write("error: detached HEAD; sms session-new requires a named branch\n")
        return 1
    t = Tree.load(cwd)
    if t.branch(branch) is None:
        sys.stderr.write(
            f"error: branch '{branch}' is not sms-tracked. "
            f"For an existing branch, run `sms adopt` to register it; "
            f"for a brand-new branch, `sms new <branch>`.\n"
        )
        return 1

    new_uuid = str(_uuid.uuid4())
    with _tree_lock(sms_root(cwd)):
        t = Tree.load(cwd)
        # parent_uuid=None: a fresh session attached to the branch (not derived from any sibling).
        existing = len(t.branch(branch)["sessions"])
        name = args.name or _default_session_name(branch, existing)
        t.add_session(branch, new_uuid, name, None, False)
        t.save()

    (sms_root(cwd) / "sessions" / branch).mkdir(parents=True, exist_ok=True)
    make_session_symlink(cwd, branch, new_uuid)

    if not args.no_materialize:
        materialize_session(cwd, new_uuid, name=name)

    report_created_session(new_uuid, name)
    return 0


def cmd_adopt(args: argparse.Namespace) -> int:
    """Register the CURRENTLY checked-out (pre-existing) git branch into the
    sms tree, then create its first (main) session.

    Sibling of `sms new`: `new` creates a brand-new branch (git checkout -b);
    `adopt` takes a branch that already exists. The branch is registered as a
    root (parent=None) since adopt doesn't change the checkout and so has no
    fork-point to record — edit tree.json or use a future `reparent` to set a
    parent later.
    """
    cwd = Path.cwd()
    branch = current_branch_or_none(cwd)
    if branch is None:
        sys.stderr.write("error: detached HEAD; sms adopt requires a named branch\n")
        return 1
    t = Tree.load(cwd)
    if t.branch(branch) is not None:
        sys.stderr.write(
            f"error: branch '{branch}' is already sms-tracked. "
            f"Use `sms session-new` to add another session.\n"
        )
        return 1

    new_uuid = str(_uuid.uuid4())
    with _tree_lock(sms_root(cwd)):
        t = Tree.load(cwd)
        t.add_branch(branch, None)
        name = args.name or _default_session_name(branch, 0)
        t.add_session(branch, new_uuid, name, None, True)
        t.save()

    (sms_root(cwd) / "sessions" / branch).mkdir(parents=True, exist_ok=True)
    make_session_symlink(cwd, branch, new_uuid)

    if not args.no_materialize:
        materialize_session(cwd, new_uuid, name=name)

    report_created_session(new_uuid, name)
    return 0


def cmd_checkout(args: argparse.Namespace) -> int:
    cwd = Path.cwd()
    result = subprocess.run(
        ["git", "checkout", args.branch],
        cwd=cwd,
    )
    if result.returncode != 0:
        return result.returncode
    return cmd_sync(argparse.Namespace())


def cmd_fork(args: argparse.Namespace) -> int:
    cwd = Path.cwd()
    parent_uuid = (
        args.from_
        or os.environ.get("CLAUDE_CODE_SESSION_ID")  # set by claude-code (VSCode extension + CLI)
        or os.environ.get("CLAUDE_SESSION_ID")        # older / alternate naming, kept as fallback
    )
    if not parent_uuid:
        sys.stderr.write(
            "error: no parent session UUID. Set CLAUDE_CODE_SESSION_ID "
            "(automatic inside Claude) or pass --from <uuid>.\n"
        )
        return 1

    # Read-only lookup outside the lock.
    t = Tree.load(cwd)
    found = t.find_session(parent_uuid)
    if found is None:
        sys.stderr.write(f"error: session {parent_uuid} not in tree.json\n")
        return 1
    branch, _parent_record = found
    new_uuid = str(_uuid.uuid4())

    # Copy files OUTSIDE the lock — new_uuid is unique so no one else races on it.
    parent_canonical = canonical_session_path(cwd, branch, parent_uuid)
    new_canonical = canonical_session_path(cwd, branch, new_uuid)
    new_canonical.parent.mkdir(parents=True, exist_ok=True)
    if parent_canonical.exists():
        shutil.copy2(parent_canonical, new_canonical)
    else:
        new_canonical.write_text("")

    parent_sub = canonical_session_subdir(cwd, branch, parent_uuid)
    if parent_sub.is_dir():
        new_sub = canonical_session_subdir(cwd, branch, new_uuid)
        shutil.copytree(parent_sub, new_sub)

    # Tree mutation under lock — quick.
    with _tree_lock(sms_root(cwd)):
        t = Tree.load(cwd)
        existing = len(t.branch(branch)["sessions"])
        name = args.name or _default_session_name(branch, existing)
        t.add_session(branch, new_uuid, name, parent_uuid, False)
        t.save()

    # Rewrite the copied jsonl's title metadata: strip the parent's
    # custom-title/agent-name lines and prepend fresh ones for the fork.
    # Appending alone isn't enough — Claude re-reads inherited entries on
    # resume and would otherwise override our title with the parent's.
    stamp_session_title(new_canonical, new_uuid, name)

    # Drop the parent's sms hook-context attachments ('You are the MAIN
    # session', 'forked from <grandparent>') copied into this fork — otherwise
    # the fork reads them as facts about itself. Its own next start re-injects
    # correct context.
    strip_inherited_sms_hook_context(new_canonical)

    # Make the fork visible wherever the parent is visible.
    #
    # Mirror the parent's existing symlinks: for every projects dir that has
    # a symlink to the parent's canonical jsonl, drop a matching symlink for
    # the new uuid. This handles the common case where the user runs
    # `/sms-fork` from inside the parent session but the worktree's current
    # git branch isn't the session's branch — without this, the fork would
    # be orphaned (no symlink anywhere, invisible to the /resume picker).
    parent_canonical = canonical_session_path(cwd, branch, parent_uuid)
    new_canonical_str = str(canonical_session_path(cwd, branch, new_uuid))
    projects_root = home_dir() / ".claude" / "projects"
    mirrored = False
    if projects_root.is_dir():
        for pd in projects_root.iterdir():
            if not pd.is_dir():
                continue
            parent_link = pd / f"{parent_uuid}.jsonl"
            if not parent_link.is_symlink():
                continue
            raw = os.readlink(parent_link)
            target = Path(raw)
            if not target.is_absolute():
                target = (parent_link.parent / target).resolve()
            if str(target) != str(parent_canonical):
                continue
            new_link = pd / f"{new_uuid}.jsonl"
            if new_link.exists() or new_link.is_symlink():
                continue
            new_link.symlink_to(new_canonical_str)
            mirrored = True

    # If we couldn't mirror anywhere (parent has no symlinks), fall back to
    # creating one in the current worktree if its branch matches.
    if not mirrored and current_branch_or_none(cwd) == branch:
        make_session_symlink(cwd, branch, new_uuid)

    report_created_session(new_uuid, name)
    return 0


def _resolve_uuid_prefix(t: Tree, prefix: str) -> tuple[str, str] | None:
    """Return (branch, uuid) for the unique session whose UUID startswith `prefix`. Or None for ambiguity / no match."""
    matches: list[tuple[str, str]] = []
    for branch_name, branch in t.data["branches"].items():
        for uuid in branch["sessions"]:
            if uuid.startswith(prefix):
                matches.append((branch_name, uuid))
    if len(matches) == 1:
        return matches[0]
    return None if not matches else ("__ambiguous__", "")


def cmd_resume(args: argparse.Namespace) -> int:
    cwd = Path.cwd()
    t = Tree.load(cwd)
    resolved = _resolve_uuid_prefix(t, args.target)
    if resolved is None:
        sys.stderr.write(f"error: no session matches '{args.target}'\n")
        return 1
    if resolved[0] == "__ambiguous__":
        sys.stderr.write(f"error: ambiguous prefix '{args.target}' matches multiple sessions\n")
        return 1
    branch, uuid = resolved

    if current_branch(cwd) != branch:
        sys.stderr.write(
            f"error: session {uuid} belongs to branch '{branch}', "
            f"but current worktree is on '{current_branch(cwd)}'. "
            f"Branch is not checked out here — run `sms checkout {branch}` first.\n"
        )
        return 1

    cmd_sync(argparse.Namespace())
    print(uuid)
    if args.no_launch:
        return 0
    os.execvp("claude", ["claude", "--resume", uuid])


def cmd_sessions(args: argparse.Namespace) -> int:
    cwd = Path.cwd()
    branch = args.branch or current_branch(cwd)
    t = Tree.load(cwd)
    b = t.branch(branch)
    if b is None:
        sys.stderr.write(f"error: branch '{branch}' not in tree.json\n")
        return 1
    for uuid, s in sorted(b["sessions"].items(), key=lambda kv: kv[1].get("created_at", "")):
        prefix = "*" if s.get("is_main") else " "
        short = uuid[:8]
        name = s.get("name", "")
        created = s.get("created_at", "")
        print(f"{prefix} {short} {created} {name}")
    return 0



def cmd_set_main(args: argparse.Namespace) -> int:
    cwd = Path.cwd()
    with _tree_lock(sms_root(cwd)):
        t = Tree.load(cwd)
        resolved = _resolve_uuid_prefix(t, args.target)
        if resolved is None:
            sys.stderr.write(f"error: no session matches '{args.target}'\n")
            return 1
        if resolved[0] == "__ambiguous__":
            sys.stderr.write(f"error: ambiguous prefix '{args.target}'\n")
            return 1
        branch, uuid = resolved
        t.set_main(branch, uuid)
        t.save()
    return 0


def _cmd_set_state(args: argparse.Namespace, state: str) -> int:
    cwd = Path.cwd()
    branch = args.branch or current_branch(cwd)
    with _tree_lock(sms_root(cwd)):
        t = Tree.load(cwd)
        t.set_state(branch, state)
        t.save()
    return 0


def cmd_mark_merged(args: argparse.Namespace) -> int:
    return _cmd_set_state(args, "merged")


def cmd_backlog(args: argparse.Namespace) -> int:
    return _cmd_set_state(args, "backlog")


def cmd_activate(args: argparse.Namespace) -> int:
    return _cmd_set_state(args, "active")


def cmd_tree(args: argparse.Namespace) -> int:
    cwd = Path.cwd()
    t = Tree.load(cwd)
    try:
        cur = current_branch(cwd)
    except SystemExit:
        cur = None

    branches = t.data["branches"]
    # Build child list
    children: dict[str | None, list[str]] = {}
    for name, b in branches.items():
        if not args.all and b.get("state") in ("merged", "backlog"):
            continue
        children.setdefault(b.get("parent"), []).append(name)
    for k in children:
        children[k].sort()

    seen: set[str] = set()

    def render(name: str, indent: int, hidden_parent: str | None = None) -> None:
        if name in seen:
            sys.stderr.write(f"warning: cycle in branch tree at '{name}'\n")
            return
        seen.add(name)
        b = branches[name]
        marker = "★" if name == cur else " "
        session_count = len(b["sessions"])
        main_name = next(
            (s["name"] for s in b["sessions"].values() if s.get("is_main") and s.get("name")),
            "",
        )
        state = b.get("state", "active")
        state_suffix = f"  [{state}]" if state != "active" else ""
        hidden_suffix = f"  (parent: {hidden_parent} [hidden])" if hidden_parent else ""
        pad = "  " * indent
        print(f"{pad}{marker} {name}  ({session_count})  {main_name}{state_suffix}{hidden_suffix}".rstrip())
        for child in children.get(name, []):
            render(child, indent + 1)

    # Roots: branches whose parent is None or whose parent is not in the (visible) set
    visible = set()
    for parent, kids in children.items():
        visible.update(kids)
    roots: list[tuple[str, str | None]] = []
    for n in sorted(visible):
        p = branches[n].get("parent")
        if p in visible:
            continue
        if p is not None and p in branches:
            # Parent exists in tree.json but was filtered out by state
            roots.append((n, p))
        else:
            roots.append((n, None))
    for root, hidden_parent in roots:
        render(root, 0, hidden_parent)
    return 0


def cmd_rules(args: argparse.Namespace) -> int:
    """Print the path to this repo's sms rules file (creating it with a default
    template if absent). Edit it with e.g. `code "$(sms rules)"`.

    The file's contents are injected into every sms session at start, so it's
    where you put standing instructions for sessions on this repo.
    """
    cwd = Path.cwd()
    path = rules_path(cwd)
    if not path.exists():
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(DEFAULT_RULES)
        sys.stderr.write(f"created default rules file at {path}\n")
    if args.show:
        print(path.read_text())
    else:
        print(path)
    return 0


def cmd_hook_session_start(args: argparse.Namespace) -> int:
    """Emit context block for current branch if it's in tree.json. Silent no-op if not."""
    cwd = Path(args.cwd).resolve() if args.cwd else Path.cwd()
    try:
        branch = current_branch(cwd)
    except (SystemExit, subprocess.CalledProcessError):
        return 0  # not a git repo or detached HEAD — silent
    try:
        t = Tree.load(cwd)
    except SystemExit:
        return 0
    b = t.branch(branch)
    if b is None:
        return 0
    parent = b.get("parent") or "<none>"
    sessions = b["sessions"]

    # Session role: if we know which session this is, tell it whether it's the
    # main session or a fork. A forked session carries a COPY of its parent's
    # transcript, so without this it reads the parent's past actions (e.g. the
    # sms-fork call that created it) as its own and re-runs them — spawning yet
    # more sessions. Print this first and prominently.
    sid = args.session_id
    if sid and sid in sessions:
        s = sessions[sid]
        sname = s.get("name") or sid[:8]
        print("=== sms session role ===")
        print(f'Your session id is {sid} (name: "{sname}").')
        if s.get("is_main"):
            print(f'You are the MAIN session of branch "{branch}".')
        else:
            pu = s.get("parent_uuid")
            if pu and pu in sessions:
                parent_label = f'{pu} (name: "{sessions[pu].get("name") or pu[:8]}")'
            elif pu:
                parent_label = pu
            else:
                parent_label = "another session"
            print(f'You are a FORKED sub-session of branch "{branch}", forked from {parent_label}.')
            print("Decide by session id, not by what the transcript shows happening:")
            print(f"  - Lines above with sessionId {sid} are YOUR actions.")
            print("  - Lines with any other sessionId are the parent's, inherited as "
                  "context when you were forked — not things you did or must repeat.")
            print(f"  - A /sms-fork you receive now forks YOU ({sid}); a fork already "
                  "shown in the inherited history was the parent forking, not a pending "
                  "task for you.")
        print()

    # User-defined rules: free-form text the user maintains in rules.md,
    # injected verbatim into every sms session. Edit via `sms rules`.
    rules_file = rules_path(cwd)
    if rules_file.exists():
        rules_text = rules_file.read_text().strip()
        if rules_text:
            print("=== sms rules ===")
            print(rules_text)
            print()

    branch_notes = sms_root(cwd) / "branches" / branch / "notes"
    branch_notes.mkdir(parents=True, exist_ok=True)
    branch_files = sorted(p.name for p in branch_notes.iterdir() if p.is_file())
    global_notes = sms_root(cwd) / "notes"
    global_notes.mkdir(parents=True, exist_ok=True)
    global_files = sorted(p.name for p in global_notes.iterdir() if p.is_file())
    main_count = sum(1 for s in sessions.values() if s.get("is_main"))
    sub_count = len(sessions) - main_count
    print("=== sms context ===")
    print(f"Branch: {branch}  (parent: {parent})")
    print(f"Sessions on this branch: {len(sessions)} ({main_count} main, {sub_count} sub)")
    print()
    print("sms branch memory — durable scratchpad shared by every session on THIS branch.")
    print(f"  Path: {branch_notes}")
    print("  Survives worktree moves (lives in .git, not the working tree).")
    print("  Use it for handoffs, findings, todos that other sessions on this branch should pick up.")
    if branch_files:
        print(f"  Existing files: {', '.join(branch_files)}")
    else:
        print("  (empty — drop markdown files here as needed.)")
    print()
    print("sms global memory — shared across ALL branches of this repo.")
    print(f"  Path: {global_notes}")
    print("  Same .git-backed, git-untracked storage; not tied to any one branch.")
    print("  Use it for repo-wide knowledge every branch should see.")
    if global_files:
        print(f"  Existing files: {', '.join(global_files)}")
    else:
        print("  (empty — drop markdown files here as needed.)")
    return 0

# -------------------------- argparse / main --------------------------------


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(prog="sms")
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_sync = sub.add_parser("sync", help="rebuild symlinks to match current branch")
    p_sync.set_defaults(func=cmd_sync)

    p_co = sub.add_parser("checkout", help="git checkout + sms sync")
    p_co.add_argument("branch")
    p_co.set_defaults(func=cmd_checkout)

    p_new = sub.add_parser("new", help="create a new branch + initial session")
    p_new.add_argument("branch")
    p_new.add_argument("--name", default=None)
    p_new.add_argument("--launch", action="store_true",
                       help="exec `claude` after setup (default: just print UUID; open in VSCode picker)")
    p_new.add_argument("--no-launch", action="store_true",
                       help=argparse.SUPPRESS)  # back-compat no-op (default is now no-launch)
    p_new.add_argument("--no-materialize", action="store_true",
                       help="skip the background `claude --print` that makes the session "
                            "visible in the picker (faster, but session may be hidden)")
    p_new.set_defaults(func=cmd_new)

    p_adopt = sub.add_parser("adopt",
                             help="register the current (pre-existing) branch into the sms tree + create its first session")
    p_adopt.add_argument("--name", default=None)
    p_adopt.add_argument("--no-materialize", action="store_true",
                         help="skip the background `claude --print` materialize step")
    p_adopt.set_defaults(func=cmd_adopt)

    p_sn = sub.add_parser("session-new",
                          help="add a new blank session to the current sms-tracked branch")
    p_sn.add_argument("--name", default=None)
    p_sn.add_argument("--no-materialize", action="store_true",
                       help="skip the background `claude --print` materialize step")
    p_sn.set_defaults(func=cmd_session_new)

    p_sd = sub.add_parser("session-delete",
                          help="delete a session entirely (canonical + symlinks + tree entry)")
    p_sd.add_argument("target", help="UUID or unique prefix")
    p_sd.set_defaults(func=cmd_session_delete)

    p_fork = sub.add_parser("fork", help="fork the current Claude session")
    p_fork.add_argument("--from", dest="from_", default=None, metavar="UUID")
    p_fork.add_argument("--name", default=None)
    p_fork.add_argument("--no-launch", action="store_true",
                       help=argparse.SUPPRESS)  # no-op: fork never launches claude
    p_fork.set_defaults(func=cmd_fork)

    p_res = sub.add_parser("resume", help="(fallback) resume a session from terminal")
    p_res.add_argument("target", help="UUID or unique prefix")
    p_res.add_argument("--no-launch", action="store_true")
    p_res.set_defaults(func=cmd_resume)

    p_ses = sub.add_parser("sessions", help="list sessions for a branch")
    p_ses.add_argument("--branch", default=None)
    p_ses.set_defaults(func=cmd_sessions)

    p_tree = sub.add_parser("tree", help="render branch tree")
    p_tree.add_argument("--all", action="store_true",
                        help="include merged and backlog branches")
    p_tree.set_defaults(func=cmd_tree)

    p_rules = sub.add_parser("rules",
                             help="print path to the repo's sms rules file (injected into every session)")
    p_rules.add_argument("--show", action="store_true", help="print the rules content instead of the path")
    p_rules.set_defaults(func=cmd_rules)

    p_sm = sub.add_parser("set-main", help="mark a session as the branch's main")
    p_sm.add_argument("target")
    p_sm.set_defaults(func=cmd_set_main)

    p_hook = sub.add_parser("hook", help="(internal) hook drivers")
    p_hook_sub = p_hook.add_subparsers(dest="hook_sub", required=True)
    p_hss = p_hook_sub.add_parser("session-start")
    p_hss.add_argument("--cwd", default=None)
    p_hss.add_argument("--session-id", default=None)
    p_hss.set_defaults(func=cmd_hook_session_start)

    for name, fn in [("mark-merged", cmd_mark_merged),
                     ("backlog", cmd_backlog),
                     ("activate", cmd_activate)]:
        p = sub.add_parser(name)
        p.add_argument("branch", nargs="?", default=None)
        p.set_defaults(func=fn)

    p_dbg = sub.add_parser("debug-paths", help="(internal) dump resolved paths")
    p_dbg.set_defaults(func=cmd_debug_paths)

    p_dt = sub.add_parser("debug-tree", help="(internal) tree.json operations")
    p_dt_sub = p_dt.add_subparsers(dest="tree_sub", required=True)
    p_dt_sub.add_parser("init")
    p_add = p_dt_sub.add_parser("add-branch")
    p_add.add_argument("name"); p_add.add_argument("parent")
    p_as = p_dt_sub.add_parser("add-session")
    p_as.add_argument("branch"); p_as.add_argument("uuid")
    p_as.add_argument("name"); p_as.add_argument("is_main")
    p_sm = p_dt_sub.add_parser("set-main")
    p_sm.add_argument("branch"); p_sm.add_argument("uuid")
    p_ss = p_dt_sub.add_parser("set-state")
    p_ss.add_argument("branch"); p_ss.add_argument("state", choices=["active", "merged", "backlog"])
    p_dt.set_defaults(func=cmd_debug_tree)

    p_ds = sub.add_parser("debug-symlink", help="(internal) symlink operations")
    p_ds_sub = p_ds.add_subparsers(dest="sym_sub", required=True)
    p_ds_make = p_ds_sub.add_parser("make")
    p_ds_make.add_argument("branch"); p_ds_make.add_argument("uuid")
    p_ds_rm = p_ds_sub.add_parser("remove")
    p_ds_rm.add_argument("uuid")
    p_ds_sub.add_parser("scan")
    p_ds_fv = p_ds_sub.add_parser("fix-visibility")
    p_ds_fv.add_argument("uuid")
    p_ds.set_defaults(func=cmd_debug_symlink)

    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
