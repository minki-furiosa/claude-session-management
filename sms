#!/usr/bin/env python3
"""sms — Session Management System."""
from __future__ import annotations

import argparse
import datetime as _dt
import fcntl
import json
import os
import subprocess
import sys
import uuid as _uuid
from contextlib import contextmanager
from pathlib import Path
from typing import Iterator, Literal


# -------------------------- Path helpers -----------------------------------


def _run_git(cwd: Path, *args: str) -> str:
    """Run a git command and return trimmed stdout. Raises CalledProcessError on failure."""
    result = subprocess.run(
        ["git", *args], cwd=cwd, check=True, capture_output=True, text=True,
    )
    return result.stdout.strip()


def find_main_git_dir(cwd: Path) -> Path:
    """Return the main repo's .git directory (not the worktree's pointer file)."""
    common = _run_git(cwd, "rev-parse", "--git-common-dir")
    p = Path(common)
    if not p.is_absolute():
        p = (cwd / p).resolve()
    return p


def current_branch(cwd: Path) -> str:
    """Return the current branch name. Raises SystemExit if HEAD is detached."""
    name = _run_git(cwd, "rev-parse", "--abbrev-ref", "HEAD")
    if name == "HEAD":
        sys.stderr.write("error: HEAD is detached; sms requires a named branch\n")
        raise SystemExit(1)
    return name


def cwd_hash(cwd: Path) -> str:
    """Claude Code's cwd-hash convention: absolute path with '/' replaced by '-'."""
    return str(cwd.resolve()).replace("/", "-")


def home_dir() -> Path:
    return Path(os.environ.get("HOME", "~")).expanduser()


def claude_projects_dir(cwd: Path) -> Path:
    return home_dir() / ".claude" / "projects" / cwd_hash(cwd)


def sms_root(cwd: Path) -> Path:
    return find_main_git_dir(cwd) / "sms"


# -------------------------- Tree class and locking ---------------------------


def _iso_now() -> str:
    return _dt.datetime.now(_dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


@contextmanager
def _tree_lock(sms_dir: Path) -> Iterator[None]:
    """Hold a file lock for the duration of a tree mutation."""
    sms_dir.mkdir(parents=True, exist_ok=True)
    lock_path = sms_dir / ".lock"
    with open(lock_path, "w") as f:
        fcntl.flock(f.fileno(), fcntl.LOCK_EX)
        try:
            yield
        finally:
            fcntl.flock(f.fileno(), fcntl.LOCK_UN)


class Tree:
    def __init__(self, path: Path, data: dict) -> None:
        self.path = path
        self.data = data

    @classmethod
    def load(cls, cwd: Path) -> "Tree":
        path = sms_root(cwd) / "tree.json"
        if not path.exists():
            return cls(path, {"branches": {}})
        try:
            data = json.loads(path.read_text())
        except json.JSONDecodeError as e:
            sys.stderr.write(
                f"error: tree.json at {path} is not valid JSON ({e}). "
                "Refusing to overwrite. Inspect manually.\n"
            )
            raise SystemExit(2)
        if not isinstance(data, dict) or "branches" not in data:
            sys.stderr.write(f"error: tree.json at {path} has unexpected shape\n")
            raise SystemExit(2)
        return cls(path, data)

    def save(self) -> None:
        self.path.parent.mkdir(parents=True, exist_ok=True)
        tmp = self.path.with_suffix(".json.tmp")
        tmp.write_text(json.dumps(self.data, indent=2, sort_keys=True) + "\n")
        os.replace(tmp, self.path)

    # --- mutators ---

    def add_branch(self, name: str, parent: str | None) -> None:
        if name in self.data["branches"]:
            sys.stderr.write(f"error: branch '{name}' already in tree.json\n")
            raise SystemExit(1)
        self.data["branches"][name] = {
            "parent": parent,
            "state": "active",
            "created_at": _iso_now(),
            "sessions": {},
        }

    def add_session(
        self, branch: str, uuid: str, name: str,
        parent_uuid: str | None, is_main: bool,
    ) -> None:
        b = self.data["branches"].get(branch)
        if b is None:
            sys.stderr.write(f"error: branch '{branch}' not in tree.json\n")
            raise SystemExit(1)
        if is_main:
            for u, s in b["sessions"].items():
                s["is_main"] = False
        b["sessions"][uuid] = {
            "name": name,
            "parent_uuid": parent_uuid,
            "is_main": is_main,
            "created_at": _iso_now(),
        }

    def set_main(self, branch: str, uuid: str) -> None:
        b = self.data["branches"].get(branch)
        if b is None or uuid not in b["sessions"]:
            sys.stderr.write(f"error: session {uuid} not on branch '{branch}'\n")
            raise SystemExit(1)
        for u, s in b["sessions"].items():
            s["is_main"] = (u == uuid)

    def set_state(self, branch: str, state: Literal["active", "merged", "backlog"]) -> None:
        if branch not in self.data["branches"]:
            sys.stderr.write(f"error: branch '{branch}' not in tree.json\n")
            raise SystemExit(1)
        self.data["branches"][branch]["state"] = state

    def find_session(self, uuid: str) -> tuple[str, dict] | None:
        for name, b in self.data["branches"].items():
            if uuid in b["sessions"]:
                return name, b["sessions"][uuid]
        return None

    def branch(self, name: str) -> dict | None:
        return self.data["branches"].get(name)


# -------------------------- Symlink helpers ----------------------------------


def canonical_session_path(cwd: Path, branch: str, uuid: str) -> Path:
    return sms_root(cwd) / "sessions" / branch / f"{uuid}.jsonl"


def canonical_session_subdir(cwd: Path, branch: str, uuid: str) -> Path:
    return sms_root(cwd) / "sessions" / branch / uuid


def make_session_symlink(cwd: Path, branch: str, uuid: str) -> None:
    canonical = canonical_session_path(cwd, branch, uuid)
    canonical.parent.mkdir(parents=True, exist_ok=True)
    link = claude_projects_dir(cwd) / f"{uuid}.jsonl"
    link.parent.mkdir(parents=True, exist_ok=True)
    if link.is_symlink():
        existing_target = Path(os.readlink(link))
        if existing_target == canonical:
            pass  # already correct
        else:
            link.unlink()
            link.symlink_to(canonical)
    elif link.exists():
        sys.stderr.write(
            f"error: {link} exists as a regular file; refusing to overwrite\n"
        )
        raise SystemExit(1)
    else:
        link.symlink_to(canonical)

    # Subdir, if canonical has one
    canonical_sub = canonical_session_subdir(cwd, branch, uuid)
    if canonical_sub.is_dir():
        sub_link = claude_projects_dir(cwd) / uuid
        if sub_link.is_symlink():
            if Path(os.readlink(sub_link)) != canonical_sub:
                sub_link.unlink()
                sub_link.symlink_to(canonical_sub, target_is_directory=True)
        elif sub_link.exists():
            sys.stderr.write(
                f"warning: {sub_link} exists as a regular directory; "
                "leaving alone\n"
            )
        else:
            sub_link.symlink_to(canonical_sub, target_is_directory=True)


def remove_session_symlink(cwd: Path, uuid: str) -> None:
    link = claude_projects_dir(cwd) / f"{uuid}.jsonl"
    if link.is_symlink():
        link.unlink()
    sub_link = claude_projects_dir(cwd) / uuid
    if sub_link.is_symlink():
        sub_link.unlink()


def scan_projects_dir_for_sms_symlinks(cwd: Path) -> dict[str, Path]:
    """Return {uuid: canonical_target} for entries that are symlinks into .git/sms/sessions/."""
    out: dict[str, Path] = {}
    projects = claude_projects_dir(cwd)
    if not projects.exists():
        return out
    sms_sessions_prefix = str(sms_root(cwd) / "sessions") + os.sep
    for entry in projects.iterdir():
        if not entry.is_symlink():
            continue
        if not entry.name.endswith(".jsonl"):
            continue
        target = os.readlink(entry)
        if not target.startswith(sms_sessions_prefix):
            continue
        uuid = entry.name[:-len(".jsonl")]
        out[uuid] = Path(target)
    return out


# -------------------------- Subcommands ------------------------------------


def cmd_debug_paths(args: argparse.Namespace) -> int:
    """Dump resolved paths for the current cwd. Used by tests."""
    cwd = Path.cwd()
    print(f"main_git_dir={find_main_git_dir(cwd)}")
    print(f"branch={current_branch(cwd)}")
    print(f"cwd_hash={cwd_hash(cwd)}")
    print(f"projects_dir={claude_projects_dir(cwd)}")
    print(f"sms_root={sms_root(cwd)}")
    return 0


def cmd_debug_tree(args: argparse.Namespace) -> int:
    """(internal) tree.json mutations used by tests."""
    cwd = Path.cwd()
    with _tree_lock(sms_root(cwd)):
        t = Tree.load(cwd)
        sub = args.tree_sub
        if sub == "init":
            pass  # load was enough
        elif sub == "add-branch":
            t.add_branch(args.name, args.parent)
        elif sub == "add-session":
            is_main = args.is_main.lower() == "true"
            t.add_session(args.branch, args.uuid, args.name, None, is_main)
        elif sub == "set-main":
            t.set_main(args.branch, args.uuid)
        elif sub == "set-state":
            t.set_state(args.branch, args.state)
        else:
            sys.stderr.write(f"error: unknown debug-tree sub {sub}\n")
            return 2
        t.save()
    return 0


def cmd_debug_symlink(args: argparse.Namespace) -> int:
    cwd = Path.cwd()
    if args.sym_sub == "make":
        make_session_symlink(cwd, args.branch, args.uuid)
    elif args.sym_sub == "remove":
        remove_session_symlink(cwd, args.uuid)
    elif args.sym_sub == "scan":
        for uuid, target in scan_projects_dir_for_sms_symlinks(cwd).items():
            print(f"{uuid}={target}")
    else:
        return 2
    return 0


def cmd_sync(args: argparse.Namespace) -> int:
    cwd = Path.cwd()
    branch = current_branch(cwd)
    t = Tree.load(cwd)

    desired_uuids: set[str] = set()
    b = t.branch(branch)
    if b is not None:
        desired_uuids = set(b["sessions"].keys())

    existing = scan_projects_dir_for_sms_symlinks(cwd)
    existing_uuids = set(existing.keys())

    sessions_root = str(sms_root(cwd) / "sessions") + os.sep
    branch_prefix = str(sms_root(cwd) / "sessions" / branch) + os.sep
    to_remove = {
        u for u in existing_uuids
        if not str(existing[u]).startswith(branch_prefix)
    }
    to_create = desired_uuids - existing_uuids

    for u in sorted(to_remove):
        remove_session_symlink(cwd, u)
    for u in sorted(to_create):
        make_session_symlink(cwd, branch, u)
    return 0


def cmd_new(args: argparse.Namespace) -> int:
    cwd = Path.cwd()
    parent = current_branch(cwd)

    # Create branch
    subprocess.run(
        ["git", "checkout", "-b", args.branch],
        cwd=cwd, check=True,
    )

    new_uuid = str(_uuid.uuid4())
    with _tree_lock(sms_root(cwd)):
        t = Tree.load(cwd)
        t.add_branch(args.branch, parent)
        t.add_session(args.branch, new_uuid, args.name or "", None, True)
        t.save()

    (sms_root(cwd) / "sessions" / args.branch).mkdir(parents=True, exist_ok=True)
    make_session_symlink(cwd, args.branch, new_uuid)

    print(new_uuid)
    if args.no_launch:
        return 0
    os.execvp("claude", ["claude", "--session-id", new_uuid])


def cmd_checkout(args: argparse.Namespace) -> int:
    cwd = Path.cwd()
    result = subprocess.run(
        ["git", "checkout", args.branch],
        cwd=cwd,
    )
    if result.returncode != 0:
        return result.returncode
    return cmd_sync(argparse.Namespace())


# -------------------------- argparse / main --------------------------------


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(prog="sms")
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_sync = sub.add_parser("sync", help="rebuild symlinks to match current branch")
    p_sync.set_defaults(func=cmd_sync)

    p_co = sub.add_parser("checkout", help="git checkout + sms sync")
    p_co.add_argument("branch")
    p_co.set_defaults(func=cmd_checkout)

    p_new = sub.add_parser("new", help="create a new branch + initial session")
    p_new.add_argument("branch")
    p_new.add_argument("--name", default=None)
    p_new.add_argument("--no-launch", action="store_true",
                       help="(testing) do not exec claude after setup")
    p_new.set_defaults(func=cmd_new)

    p_dbg = sub.add_parser("debug-paths", help="(internal) dump resolved paths")
    p_dbg.set_defaults(func=cmd_debug_paths)

    p_dt = sub.add_parser("debug-tree", help="(internal) tree.json operations")
    p_dt_sub = p_dt.add_subparsers(dest="tree_sub", required=True)
    p_dt_sub.add_parser("init")
    p_add = p_dt_sub.add_parser("add-branch")
    p_add.add_argument("name"); p_add.add_argument("parent")
    p_as = p_dt_sub.add_parser("add-session")
    p_as.add_argument("branch"); p_as.add_argument("uuid")
    p_as.add_argument("name"); p_as.add_argument("is_main")
    p_sm = p_dt_sub.add_parser("set-main")
    p_sm.add_argument("branch"); p_sm.add_argument("uuid")
    p_ss = p_dt_sub.add_parser("set-state")
    p_ss.add_argument("branch"); p_ss.add_argument("state", choices=["active", "merged", "backlog"])
    p_dt.set_defaults(func=cmd_debug_tree)

    p_ds = sub.add_parser("debug-symlink", help="(internal) symlink operations")
    p_ds_sub = p_ds.add_subparsers(dest="sym_sub", required=True)
    p_ds_make = p_ds_sub.add_parser("make")
    p_ds_make.add_argument("branch"); p_ds_make.add_argument("uuid")
    p_ds_rm = p_ds_sub.add_parser("remove")
    p_ds_rm.add_argument("uuid")
    p_ds_sub.add_parser("scan")
    p_ds.set_defaults(func=cmd_debug_symlink)

    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
