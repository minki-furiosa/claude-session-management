#!/usr/bin/env python3
"""sms — Session Management System."""
from __future__ import annotations

import argparse
import datetime as _dt
import fcntl
import filecmp
import json
import os
import shutil
import subprocess
import sys
import uuid as _uuid
from contextlib import contextmanager
from pathlib import Path
from typing import Iterator, Literal


# -------------------------- Path helpers -----------------------------------


def _run_git(cwd: Path, *args: str) -> str:
    """Run a git command and return trimmed stdout. Raises CalledProcessError on failure."""
    result = subprocess.run(
        ["git", *args], cwd=cwd, check=True, capture_output=True, text=True,
    )
    return result.stdout.strip()


def find_main_git_dir(cwd: Path) -> Path:
    """Return the main repo's .git directory (not the worktree's pointer file)."""
    common = _run_git(cwd, "rev-parse", "--git-common-dir")
    p = Path(common)
    if not p.is_absolute():
        p = (cwd / p).resolve()
    return p


def current_branch(cwd: Path) -> str:
    """Return the current branch name. Raises SystemExit if HEAD is detached."""
    name = _run_git(cwd, "rev-parse", "--abbrev-ref", "HEAD")
    if name == "HEAD":
        sys.stderr.write("error: HEAD is detached; sms requires a named branch\n")
        raise SystemExit(1)
    return name


def current_branch_or_none(cwd: Path) -> str | None:
    """Like current_branch but returns None on detached HEAD (no error)."""
    name = _run_git(cwd, "rev-parse", "--abbrev-ref", "HEAD")
    return None if name == "HEAD" else name


def cwd_hash(cwd: Path) -> str:
    """Claude Code's cwd-hash convention: absolute path with '/' replaced by '-'."""
    return str(cwd.resolve()).replace("/", "-")


def home_dir() -> Path:
    return Path(os.environ.get("HOME", "~")).expanduser()


def claude_projects_dir(cwd: Path) -> Path:
    return home_dir() / ".claude" / "projects" / cwd_hash(cwd)


def sms_root(cwd: Path) -> Path:
    return find_main_git_dir(cwd) / "sms"


def rules_path(cwd: Path) -> Path:
    """User-editable rules file, injected into every sms session on this repo."""
    return sms_root(cwd) / "rules.md"


DEFAULT_RULES = """\
